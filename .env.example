# Copy to .env and fill in your values:
#   cp .env.example .env
#
# ChemCrow loads this file automatically via python-dotenv.

# Required (Claude / Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — only needed if you use OpenAI models or want OpenAI embeddings for literature search
OPENAI_API_KEY=

# Optional — web search tool (https://serpapi.com)
SERP_API_KEY=

# Optional — reaction tools via IBM RXN4Chem (skip if using Docker with local_rxn=True)
RXN4CHEM_API_KEY=

# Optional — molecule pricing lookup (https://chem-space.com)
CHEMSPACE_API_KEY=

# Optional — improves literature search paper discovery
SEMANTIC_SCHOLAR_API_KEY=

# Optional — override reaction service URLs (set automatically in docker-compose)
# RXN_PREDICT_URL=http://localhost:8051/api/v1/run
# RXN_RETRO_URL=http://localhost:8052/api/v1/run
